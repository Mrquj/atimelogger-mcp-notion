# ---- ATimeLogger MCP remote server configuration ----
# Copy to `.env` and fill in. All values are read from the process environment.

# REQUIRED. Personal Access Token generated in the ATimeLogger web app:
#   Settings -> API Tokens -> Generate token  (shown only once, starts with atl_pat_)
ATL_TOKEN=atl_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL. ATimeLogger backend base URL. Defaults to production.
# ATL_BASE_URL=https://app.atimelogger.pro

# STRONGLY RECOMMENDED for a public URL. Shared secret required to call /mcp.
# Clients send it as `Authorization: Bearer <token>`, header `x-mcp-token`,
# or `?token=` query. Leave empty to expose the endpoint without auth.
MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# OPTIONAL. Port the HTTP server listens on (host platforms usually inject this).
PORT=3000

# OPTIONAL. Path of the Streamable HTTP MCP endpoint (default /mcp).
# MCP_PATH=/mcp
